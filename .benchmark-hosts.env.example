# Copy to .benchmark-hosts.env and customize for your environment.
# This file is intentionally safe to commit; .benchmark-hosts.env is gitignored.

# SSH targets
export FNEC_HOST_T480="dc0sk@192.168.121.50"
export FNEC_HOST_PI5="dc0sk@192.168.121.49"

# Remote repo path under $HOME for benchmark sync/runs
export FNEC_REMOTE_REPO_SUBDIR="git/fnec-rust"

# Optional default target used by scripts/pi-remote-benchmark.sh
# export FNEC_BENCH_TARGET="$FNEC_HOST_T480"
